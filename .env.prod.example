SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:postgresql://postgres:5432/pos_db
DB_USERNAME=pos_user
DB_PASSWORD=replace-with-postgres-password
POSTGRES_PASSWORD=replace-with-postgres-password

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=replace-with-at-least-32-random-characters-change-this
